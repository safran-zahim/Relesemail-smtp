# Docker Port Configuration
# Host port for the application (container runs on port 3000)
# Change this to run on a different port (e.g., 3001, 8080, 5173)
HOST_PORT=3000

# Other environment variables
NODE_ENV=production

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MY_SECRET_KEY=
